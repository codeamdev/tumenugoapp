# URL base del backend web (sin slash al final)
# Ejemplos:
#   desarrollo local:  http://192.168.1.X:3000
#   producción:        https://tu-dominio.com
EXPO_PUBLIC_TENANT_URL=http://192.168.1.X:3000

# Slug del tenant para modo white-label (app de un solo establecimiento).
# Dejar vacío para modo multi-tenant: el usuario elige el establecimiento al iniciar sesión.
EXPO_PUBLIC_TENANT_SLUG=
